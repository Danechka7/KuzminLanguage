<Page x:Class="KuzminLanguage.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KuzminLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <ListView Name="ClientListView" Grid.Row="1" Grid.ColumnSpan="5">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Image Width="150" Grid.Column="0" Grid.RowSpan="5" Stretch="UniformToFill" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="ImagePath">
                                    <Binding.TargetNullValue>
                                        <ImageSource>
                                            /res/school_logo.png
                                        </ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>
                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding FullName}" FontSize="20"></TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding Genderous}" FontSize="15" Grid.Row="1" Grid.Column="1"></TextBlock>
                        <TextBlock Text="{Binding Phone, StringFormat=Телефон: {0}}" FontSize="15" Grid.Row="1" Grid.Column="2"></TextBlock>
                        <TextBlock Text="{Binding Email, StringFormat=e-mail: {0}}" FontSize="15" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"></TextBlock>
                        <TextBlock Text="{Binding BirthdayDateString, StringFormat=Дата рождения: {0}}" FontSize="15" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"></TextBlock>
                        <TextBlock Text="{Binding RegisterDateString, StringFormat=Дата регистрации: {0}}" FontSize="15" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"></TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
