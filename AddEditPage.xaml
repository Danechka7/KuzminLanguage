<Page x:Class="KuzminLanguage.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KuzminLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="400"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="0" Grid.Row="0" Text="Идентификатор" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Column="1" Grid.Row="0" Margin="10" Name="TBoxID"></TextBox>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="Фамилия" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Column="1" Grid.Row="1" Margin="10" Name="TBoxFirstName"></TextBox>

        <TextBlock Grid.Column="0" Grid.Row="2" Text="Имя" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Column="1" Grid.Row="2" Margin="10" Name="TBoxLastName"></TextBox>

        <TextBlock Grid.Column="0" Grid.Row="3" Text="Отчество" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Column="1" Grid.Row="3" Margin="10" Name="TBoxPathronic"></TextBox>

        <TextBlock Grid.Column="0" Grid.Row="4" Text="Почта" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Column="1" Grid.Row="4" Margin="10" Name="TBoxEmail"></TextBox>

        <TextBlock Grid.Column="0" Grid.Row="5" Text="Телефон" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <TextBox Grid.Column="1" Grid.Row="5" Margin="10" Name="TBoxPhone"></TextBox>

        <TextBlock Grid.Column="0" Grid.Row="6" Text="Дата рождения" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <DatePicker Grid.Column="1" Grid.Row="6" Margin="10" Name="BirthDate"></DatePicker>

        <TextBlock Grid.Column="0" Grid.Row="7" Text="Пол" FontSize="25" VerticalAlignment="Center" Margin="5"></TextBlock>
        <ComboBox Name="ComboGender" Grid.Column="1" Grid.Row="7" Margin="10" SelectionChanged="ComboGender_SelectionChanged">
            <TextBlock>Мужской</TextBlock>
            <TextBlock>Женский</TextBlock>
        </ComboBox>

        <TextBlock Grid.Column="2" Grid.Row="0" Text="Фото" FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5"></TextBlock>
        <Image Grid.Column="2" Grid.Row="1" Grid.RowSpan="4" Margin="10" Name="ClientImage" Stretch="Uniform">
            <Image.Source>
                <Binding Path="ImagePath">
                    <Binding.TargetNullValue>
                        <ImageSource>
                            /res/school_logo.png
                        </ImageSource>
                    </Binding.TargetNullValue>
                </Binding>
            </Image.Source>
        </Image>
        <Button Grid.Column="2" Grid.Row="5" Width="200" Content="Выбрать другую..." Name="SelectPhotoBtn" Click="SelectPhotoBtn_Click"></Button>

        <Button Grid.Column="0" Grid.Row="8" Grid.ColumnSpan="3" Width="200" Content="Сохранить" Name="SaveBtn" Click="SaveBtn_Click"></Button>
    </Grid>
</Page>
